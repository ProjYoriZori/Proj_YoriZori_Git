{
  "expo": {
    "name": "YoriJori",
    "slug": "yorijori-recipe-app",
    "version": "0.3.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "yorijori",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#f7fbf6"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "apiBaseUrl": ""
    }
  }
}
